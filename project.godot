; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="BogJamSummer2025"
run/main_scene="uid://b28ucq72rnd44"
config/features=PackedStringArray("4.4", "GL Compatibility")
boot_splash/bg_color=Color(0, 0, 0, 1)
boot_splash/image="uid://bvqbrliccv0iq"
config/icon="res://godot.svg"

[autoload]

AudioHandler="*res://utils/globals/audio_handler/audio_handler.tscn"
EventHandler="*res://utils/globals/event_handler/event_handler.tscn"
GlobalVar="*res://utils/globals/global_var/global_var.tscn"
Vfx="*res://utils/globals/vfx/vfx.tscn"
DialogueManager="*res://addons/dialogue_manager/dialogue_manager.gd"

[debug]

gdscript/warnings/unused_signal=0

[display]

window/size/viewport_width=640
window/size/viewport_height=480
window/size/mode=3
window/stretch/mode="canvas_items"
window/name="BogJamSummer2025"

[editor_plugins]

enabled=PackedStringArray("res://addons/dialogue_manager/plugin.cfg")

[file_customization]

folder_colors={
"res://addons/": "gray",
"res://entities/": "orange",
"res://ui/": "green",
"res://utils/": "blue"
}

