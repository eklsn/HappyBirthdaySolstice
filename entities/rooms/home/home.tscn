[sub_resource type="GDScript" id="GDScript_e4dc0"]
script/source = "extends ColorRect

var enabled : bool = false

@export var min_alpha : float = 0.5
@export var max_alpha : float = 1.0
@export var min_wait : float = 0.0
@export var max_wait : float = 0.55
@export var flash_duration : float = 0.05
@export var flashes : int = 10

var cur_alpha : float = 0.5

func start() -> void:
	enabled  = true
	color = Color(1.0,1.0,1.0,0.0)
	position = get_node(\"../Player\").position - Vector2(320,320) # i get the terminal vibes from node management bruh
	size = Vector2(640,480)
	visible = true
	var i : int
	while i < flashes:
		cur_alpha = max_alpha
		await get_tree().create_timer(flash_duration).timeout
		cur_alpha = min_alpha
		await get_tree().create_timer(randf_range(min_wait,max_wait)).timeout
		i+=1
	enabled = false

func _process(delta: float) -> void:
	if !enabled:
		color.a = lerp(color.a,0.0,0.01)
	else:
		color.a = lerp(color.a,cur_alpha,0.1)
		
"

[sub_resource type="GDScript" id="GDScript_bh2li"]
script/source = "extends PointLight2D

@export var min_energy : float = 0.75
@export var max_energy : float = 3.25
@export var min_scale : Vector2 = Vector2(1,1)
@export var max_scale : Vector2 = Vector2(3,3)
@export var scale_speed : float = 0.05
@export var energy_speed : float = 0.05
@export var script_enabled : bool = true

var target_scale : Vector2 = max_scale
var target_energy : float


func _process(delta: float) -> void:
	if script_enabled:
		scale = lerp(scale, target_scale, scale_speed)
		energy = lerp(energy, target_energy, energy_speed)
	if scale >= max_scale-Vector2(0.01,0.01):
		target_scale = min_scale
	if scale <= min_scale+Vector2(0.01,0.01):
		target_scale = max_scale
	if energy >= max_energy-0.01:
		target_energy = min_energy
	if energy <= min_energy+0.01:
		target_energy = max_energy
	
"

